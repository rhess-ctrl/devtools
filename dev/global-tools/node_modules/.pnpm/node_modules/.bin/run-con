#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/run-con@1.3.2/node_modules/run-con/node_modules:/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/run-con@1.3.2/node_modules:/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/run-con@1.3.2/node_modules/run-con/node_modules:/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/run-con@1.3.2/node_modules:/Users/RHESS/github/eswat2/devtools/dev/global-tools/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../run-con/cli.js" "$@"
else
  exec node  "$basedir/../run-con/cli.js" "$@"
fi
